# CoC API key van https://developer.clashofclans.com/ (IP-locked op de cron-host)
COC_API_KEY=
# Discord bot-token. De bot post de banner en zet de reactie (🔥/🤡).
# Bot moet in de server zitten met View Channel + Send Messages + Attach Files
# + Add Reactions in het doelkanaal (channelId staat in config.json).
DISCORD_BOT_TOKEN=
