# CoC API key van https://developer.clashofclans.com/ (IP-locked op de cron-host)
COC_API_KEY=
# Discord webhook-URL van het doelkanaal
DISCORD_WEBHOOK_URL=
# Optioneel: Discord bot-token om een reactie (🔥/🤡) onder de post te zetten.
# Bot moet in de server zitten met 'Add Reactions'-recht. Leeg = geen reacties.
DISCORD_BOT_TOKEN=
